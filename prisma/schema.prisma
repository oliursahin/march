generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String        @id @default(cuid())
  email       String        @unique
  name        String?
  avatarUrl   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  objects     EmailObject[]
  gmailTokens GmailTokens?
}

model GmailTokens {
  id           String    @id @default(cuid())
  userId       String    @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime?
  historyId    String?
  email        String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailObject {
  id              String      @id @default(cuid())
  gmailId         String      @unique
  userId          String
  subject         String
  senderName      String
  senderEmail     String
  bodyText        String
  receivedAt      DateTime
  gmailUrl        String
  dueDate         DateTime?
  metadata        Json?
  status          EmailStatus @default(INBOX)
  statusChangedAt DateTime    @default(now())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([receivedAt])
}

enum EmailStatus {
  INBOX
  LATER
  ARCHIVED
}
